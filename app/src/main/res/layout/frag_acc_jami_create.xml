<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_primary_dark"
    tools:context="com.avatok.comms.account.AccountWizardActivity">

    <com.avatok.comms.views.BoundedRelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:bounded_height="670dp">

        <!--
          Davy 2026-05-27: the original Jami layout had a faded
          person-silhouette watermark + a "Create your AvaTok account"
          headline on top. Both removed in favour of the AvaTok logo
          sitting where the silhouette was — testers find the three-
          headline stack (login → 'Create AvaTok account' button →
          'Create your AvaTok account' title) confusing.
        -->
        <ImageView
            android:id="@+id/background"
            android:layout_width="@dimen/wizard_image_background"
            android:layout_height="@dimen/wizard_image_background"
            android:layout_alignTop="@id/pager"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="-200dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_avatok_logo" />

        <!-- Title kept in tree as visibility=gone so any view-binding
             reference in JamiAccountCreationFragment.kt keeps compiling.
             "@string/account_creation_ring" already says "Create your
             AvaTok account" but we surface that intent via the AvaTok
             logo + the button label inside the card. -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:layout_margin="@dimen/text_margin"
            android:gravity="center"
            android:text="@string/account_creation_ring"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5"
            android:textColor="@color/color_primary_light"
            android:textStyle="bold"
            android:visibility="gone" />

        <com.avatok.comms.views.WizardViewPager
            android:id="@+id/pager"
            android:layout_width="@dimen/wizard_card_width"
            android:layout_height="@dimen/wizard_card_height"
            android:layout_above="@+id/indicator"
            android:layout_centerHorizontal="true"
            android:clipChildren="false"
            android:clipToPadding="false"/>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/indicator"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            app:tabBackground="@drawable/tab_selector"
            android:background="@color/color_primary_dark"
            app:tabGravity="center"
            app:tabIndicatorHeight="0dp"/>

    </com.avatok.comms.views.BoundedRelativeLayout>

</FrameLayout>
