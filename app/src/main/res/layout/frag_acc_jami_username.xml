<?xml version="1.0" encoding="utf-8"?>
<!--
  AvaTok onboarding — 02 Choose username (pager page 0).
  Sticker card. IDs preserved for JamiAccountUsernameFragment:
  input_username, input_username_txt_box, ring_username_availability_spinner,
  create_account_username, skip.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context="com.avatok.comms.account.AccountWizardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:background="@drawable/avatok_card"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="32dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="@string/avatok_username_title"
                android:textAppearance="@style/TextAppearance.AvaTok.CardTitle" />

            <TextView
                android:id="@+id/status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/avatok_badge_green"
                android:paddingStart="13dp"
                android:paddingEnd="16dp"
                android:paddingTop="7dp"
                android:paddingBottom="10dp"
                android:text="@string/avatok_recommended"
                android:textColor="@color/avatok_ink"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_username_txt_box"
                style="@style/Widget.AvaTok.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_avatok_person">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="username"
                    android:hint="@string/avatok_username_hint"
                    android:inputType="text"
                    android:lines="1"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <ProgressBar
                android:id="@+id/ring_username_availability_spinner"
                style="?android:attr/progressBarStyle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:visibility="invisible" />

        </FrameLayout>

        <Button
            android:id="@+id/create_account_username"
            style="@style/Widget.AvaTok.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:enabled="false"
            android:text="@string/avatok_choose_username_btn" />

        <Button
            android:id="@+id/skip"
            style="@style/Widget.AvaTok.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/avatok_skip_username" />

    </LinearLayout>
</FrameLayout>
