<?xml version="1.0" encoding="utf-8"?>
<!--
  AvaTok onboarding — 05 Notifications pre-prompt (sticker modal).
  Shown by AccountWizardActivity before the system POST_NOTIFICATIONS
  request. Buttons: notif_allow (→ request permission / finish),
  notif_deny (→ finish without asking again here).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@drawable/avatok_card"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="26dp"
    android:paddingTop="30dp"
    android:paddingEnd="34dp"
    android:paddingBottom="34dp">

    <FrameLayout
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/avatok_avatar_yellow"
        android:foreground="@drawable/avatok_avatar_ring">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_avatok_bell" />

    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="@string/avatok_notif_title"
        android:textAppearance="@style/TextAppearance.AvaTok.CardTitle" />

    <Button
        android:id="@+id/notif_allow"
        style="@style/Widget.AvaTok.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/avatok_notif_allow" />

    <Button
        android:id="@+id/notif_deny"
        style="@style/Widget.AvaTok.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/avatok_btn_ghost"
        android:text="@string/avatok_notif_deny" />

</LinearLayout>
