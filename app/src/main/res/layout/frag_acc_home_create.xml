<?xml version="1.0" encoding="utf-8"?>
<!--
  AvaTok onboarding — 01 Welcome.
  Sticker design: teal page (from Theme.AvaTok.Onboarding), centred
  logo mark, headline + subtitle, single yellow "Get started" CTA.
  ring_create_btn is kept (HomeAccountCreationFragment binds it) and
  now drives presenter.clickOnCreateAccount() on tap.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".account.AccountWizardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="26dp"
        android:paddingVertical="40dp">

        <ImageView
            android:id="@+id/imageView6"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_avatok_logo_mark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:text="@string/avatok_welcome_title"
            android:textAppearance="@style/TextAppearance.AvaTok.WelcomeTitle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:maxWidth="300dp"
            android:text="@string/avatok_welcome_sub"
            android:textAppearance="@style/TextAppearance.AvaTok.Body" />

        <Button
            android:id="@+id/ring_create_btn"
            style="@style/Widget.AvaTok.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="38dp"
            android:drawableEnd="@drawable/ic_avatok_arrow"
            android:drawablePadding="10dp"
            android:text="@string/avatok_get_started" />

    </LinearLayout>
</ScrollView>
