<?xml version="1.0" encoding="utf-8"?>
<!--
  AvaTok onboarding — 04 Create profile (pager page 2).
  Sticker card. IDs preserved for ProfileCreationFragment:
  profile_photo, gallery, camera, remove_photo, username_box, username,
  next_create_account, skip_create_account, profile_container.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context="com.avatok.comms.account.AccountWizardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:background="@drawable/avatok_card"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="32dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="@string/avatok_profile_title"
                android:textAppearance="@style/TextAppearance.AvaTok.CardTitle" />

            <TextView
                android:id="@+id/status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/avatok_badge_cyan"
                android:paddingStart="13dp"
                android:paddingEnd="16dp"
                android:paddingTop="7dp"
                android:paddingBottom="10dp"
                android:text="@string/avatok_optional"
                android:textColor="@color/avatok_ink"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/profile_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp">

            <ImageView
                android:id="@+id/profile_photo"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/avatok_avatar_yellow"
                android:foreground="@drawable/avatok_avatar_ring"
                android:contentDescription="@null"
                tools:src="@drawable/ic_contact_picture_fallback" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="-12dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/gallery"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/avatok_chip_circle"
                    android:contentDescription="@string/open_the_gallery"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_avatok_image" />

                <ImageButton
                    android:id="@+id/camera"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/avatok_chip_circle"
                    android:contentDescription="@string/take_a_photo"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_avatok_camera" />

                <ImageButton
                    android:id="@+id/remove_photo"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/avatok_chip_circle"
                    android:contentDescription="@string/remove_photo"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_avatok_x"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </LinearLayout>

        </FrameLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/username_box"
            style="@style/Widget.AvaTok.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:startIconDrawable="@drawable/ic_avatok_person">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="name"
                android:hint="@string/avatok_enter_name"
                android:inputType="textCapWords" />

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/next_create_account"
            style="@style/Widget.AvaTok.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/avatok_save_profile" />

        <Button
            android:id="@+id/skip_create_account"
            style="@style/Widget.AvaTok.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/avatok_skip_later" />

    </LinearLayout>
</FrameLayout>
