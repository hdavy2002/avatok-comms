<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/qr_image"
        android:contentDescription="@string/qrcode_to_scan"
        android:layout_width="@dimen/qr_code_size"
        android:layout_height="@dimen/qr_code_size"
        android:layout_marginTop="16dp"
        android:background="@color/design_default_color_background"
        android:padding="@dimen/padding_small"
        android:scaleType="fitCenter"
        tools:src="@drawable/baseline_qr_code_2_black_24dp"
        tools:tint="@color/color_primary_dark" />

    <TextView
        android:id="@+id/share_instruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="8dp"
        android:text="@string/share_message"
        android:textColor="@color/colorOnSurface"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/share_button"
        style="@style/ButtonColored"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/share_your_account_information" />

    <TextView
        android:id="@+id/my_id_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:ellipsize="middle"
        android:fontFamily="monospace"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/colorOnSurface"
        android:textIsSelectable="true"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/copy_id_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/copy_id_label" />

    <EditText
        android:id="@+id/paste_id_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:autofillHints=""
        android:hint="@string/paste_id_hint"
        android:inputType="textNoSuggestions"
        android:maxLines="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_from_id_button"
        style="@style/ButtonColored"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:text="@string/add_from_id" />

</LinearLayout>