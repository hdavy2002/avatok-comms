<?xml version="1.0" encoding="utf-8"?>
<!--
  AvaTok welcome / landing screen.

  Pure native Kotlin layout — replaces the previous WebView-based
  login that loaded avatok.ai/login in an iframe-like surface and
  looked messy in mobile dimensions.

  Layout intent (proof-of-concept for investor demos):
    1. Big AvaTok logo, centered.
    2. "Welcome to AvaTok" headline.
    3. One-line subtitle.
    4. "Get started" CTA — taps through to AccountWizardActivity
       which is configured to auto-skip its own welcome fragment
       and land the user directly on the username-pick page.

  No auth, no WebView, no backend roundtrip on this surface. The
  real avatok.ai login + identity binding is the deferred work
  davy will revisit once the demo flow is locked.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <ImageView
            android:id="@+id/avatok_landing_logo"
            android:layout_width="160dp"
            android:layout_height="148dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_avatok_logo" />

        <TextView
            android:id="@+id/avatok_landing_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="@string/avatok_welcome_title"
            android:textColor="#0F1F2A"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/avatok_landing_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="@string/avatok_welcome_subtitle"
            android:textColor="#475565"
            android:textSize="15sp"
            android:lineSpacingExtra="3sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/avatok_landing_proceed"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:text="@string/avatok_welcome_proceed"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="#0F4C75"
            android:drawableEnd="@drawable/baseline_arrow_forward_white_18"
            app:cornerRadius="28dp" />

    </LinearLayout>

</FrameLayout>
