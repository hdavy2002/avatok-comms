<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher foreground.

  Android adaptive icons (API 26+) are 108x108dp with a 72x72dp
  "safe zone" in the center. The A is shifted into that safe zone
  so OEM masks (circle / squircle / etc.) don't crop it.

  Math: SVG viewport was 120x110. Center the original 120x110
  shape inside a 108x108 viewport — that needs scale 72/120 = 0.6,
  then translate to center.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:scaleX="0.6"
        android:scaleY="0.6"
        android:translateX="18"
        android:translateY="21">

        <!-- Teal "A" stroke. -->
        <path
            android:pathData="M 22 95 L 60 15 L 98 95"
            android:strokeColor="#1FB5B0"
            android:strokeWidth="22"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />

        <!-- Coral dot. -->
        <path
            android:pathData="M 60 78 m -8 0 a 8 8 0 1 0 16 0 a 8 8 0 1 0 -16 0 z"
            android:fillColor="#FF5350" />
    </group>
</vector>
