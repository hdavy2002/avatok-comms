<?xml version="1.0" encoding="utf-8"?>
<!-- Disabled primary button: muted fill, muted border + shadow. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="@dimen/avatok_shadow_btn" android:top="@dimen/avatok_shadow_btn">
        <shape android:shape="rectangle">
            <solid android:color="@color/avatok_disabled_border" />
            <corners android:radius="@dimen/avatok_radius_pill" />
        </shape>
    </item>
    <item android:right="@dimen/avatok_shadow_btn" android:bottom="@dimen/avatok_shadow_btn">
        <shape android:shape="rectangle">
            <solid android:color="@color/avatok_disabled_bg" />
            <stroke android:width="@dimen/avatok_border" android:color="@color/avatok_disabled_border" />
            <corners android:radius="@dimen/avatok_radius_pill" />
        </shape>
    </item>
</layer-list>
