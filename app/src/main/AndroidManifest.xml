<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions our app will need over its full Phase-2-to-6 build.
         Granular runtime grants happen in code; declaring them here is
         the manifest contract with the OS. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL"
                     tools:ignore="ForegroundServicePermission" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"
                     tools:ignore="ForegroundServicePermission" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA"
                     tools:ignore="ForegroundServicePermission" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Bluetooth (Phase 4+ — for headset routing). -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <application
        android:name=".AvaTokApplication"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:supportsRtl="true"
        android:allowBackup="false"
        android:usesCleartextTraffic="false"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service that owns the libjami daemon lifecycle.
             Stub in Phase 3 commit 3a (compiles, starts foreground notification
             but doesn't yet boot the daemon). Commit 3b wires libjamiclient
             DaemonService injection + actual startDaemon() call. -->
        <service
            android:name=".services.JamiDaemonService"
            android:exported="false"
            android:foregroundServiceType="microphone|camera|phoneCall" />

    </application>
</manifest>
